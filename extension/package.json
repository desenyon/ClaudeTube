{
  "name": "claudetube",
  "displayName": "ClaudeTube",
  "description": "YouTube in your Cursor sidebar — watch, queue, and agent-control videos while you code with Claude",
  "version": "2.0.0",
  "publisher": "desenyon",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/desenyon/ClaudeTube#readme",
  "bugs": {
    "url": "https://github.com/desenyon/ClaudeTube/issues"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/desenyon/ClaudeTube.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "youtube",
    "cursor",
    "claude",
    "sidebar",
    "player",
    "video"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudetube",
          "title": "ClaudeTube",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudetube": [
        {
          "type": "webview",
          "id": "claudetube.player",
          "name": "Player"
        }
      ]
    },
    "commands": [
      {
        "command": "claudetube.playUrl",
        "title": "Play URL",
        "category": "ClaudeTube",
        "icon": "$(play)"
      },
      {
        "command": "claudetube.playUrlAtCursor",
        "title": "Play URL at Cursor",
        "category": "ClaudeTube"
      },
      {
        "command": "claudetube.playVideoId",
        "title": "Play Video ID",
        "category": "ClaudeTube"
      },
      {
        "command": "claudetube.enqueue",
        "title": "Add to Queue",
        "category": "ClaudeTube",
        "icon": "$(add)"
      },
      {
        "command": "claudetube.togglePlay",
        "title": "Toggle Play/Pause",
        "category": "ClaudeTube",
        "icon": "$(debug-pause)"
      },
      {
        "command": "claudetube.next",
        "title": "Play Next in Queue",
        "category": "ClaudeTube",
        "icon": "$(skip-forward)"
      },
      {
        "command": "claudetube.show",
        "title": "Show Player",
        "category": "ClaudeTube",
        "icon": "$(device-camera-video)"
      },
      {
        "command": "claudetube.clearQueue",
        "title": "Clear Queue",
        "category": "ClaudeTube"
      },
      {
        "command": "claudetube.copyCurrentUrl",
        "title": "Copy Current Video URL",
        "category": "ClaudeTube"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "claudetube.playUrlAtCursor",
          "when": "editorHasSelection",
          "group": "navigation@99"
        }
      ],
      "commandPalette": [
        {
          "command": "claudetube.playUrl"
        },
        {
          "command": "claudetube.playUrlAtCursor"
        },
        {
          "command": "claudetube.enqueue"
        },
        {
          "command": "claudetube.togglePlay"
        },
        {
          "command": "claudetube.next"
        },
        {
          "command": "claudetube.show"
        },
        {
          "command": "claudetube.copyCurrentUrl"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudetube.togglePlay",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y"
      },
      {
        "command": "claudetube.show",
        "key": "ctrl+shift+0",
        "mac": "cmd+shift+0"
      },
      {
        "command": "claudetube.next",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+."
      }
    ],
    "configuration": {
      "title": "ClaudeTube",
      "properties": {
        "claudetube.defaultLayout": {
          "type": "string",
          "enum": ["compact", "theater", "mini"],
          "default": "compact",
          "description": "Default player layout"
        },
        "claudetube.defaultPlaybackRate": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 2,
          "description": "Default playback speed"
        },
        "claudetube.miniOpacity": {
          "type": "number",
          "default": 1,
          "minimum": 0.3,
          "maximum": 1,
          "description": "Opacity for mini player mode"
        },
        "claudetube.autoplay": {
          "type": "boolean",
          "default": true,
          "description": "Autoplay when a new video is loaded"
        },
        "claudetube.agentInboxEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Watch .claudetube/inbox.json for agent commands"
        },
        "claudetube.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show now-playing item in the status bar"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "lint": "tsc --noEmit",
    "test": "node run-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
